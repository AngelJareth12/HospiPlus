@{
    ViewBag.Title = "ConfirmarCita";
    Layout = null;
}

<link href="~/Content/ConfirmarCitaStyle.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<div class="floating-particles">
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
    <div class="particle"></div>
</div>

<div class="confirmation-container">
    <div class="confirmation-header">
        <h2>
            <i class="fas fa-calendar-check header-icon"></i>
            CONFIRMACIÓN DE CITA
        </h2>
    </div>

    <div class="confirmation-body">
        @if (TempData["Mensaje"] != null)
        {
            <div class="alert alert-warning">
                <i class="fas fa-info-circle alert-icon"></i>
                <span>@TempData["Mensaje"]</span>
            </div>
        }

        <form action="@Url.Action("EnviarConfirmacionCita", "Home")" method="post" class="space-y-4">
            @Html.AntiForgeryToken()

            <div class="form-group">
                <label for="emailPaciente">
                    <i class="fas fa-envelope label-icon"></i>
                    Ingrese su correo electrónico:
                </label>
                <div class="input-wrapper">
                    <input type="email"
                           class="form-control"
                           id="emailPaciente"
                           name="emailPaciente"
                           placeholder="ejemplo@correo.com"
                           required />
                    <i class="fas fa-at input-icon"></i>
                </div>
                <small style="color: #999; font-size: 0.9em; margin-top: 5px; display: block;">
                    <i class="fas fa-info-circle"></i>
                    Se enviarán las confirmaciones de todas sus citas activas asociadas a este correo.
                </small>
            </div>

            <div class="text-center">
                <button type="submit" class="btn-warning">
                    <i class="fas fa-paper-plane btn-icon"></i>
                    Recibir la confirmación de mi cita
                </button>
            </div>
            <div style="margin-top: 15px;">
                <a href="@Url.Action("Index", "Home")" class="btn-warning" style="text-decoration: none;">
                    <i class="fas fa-home btn-icon"></i>
                    Regresar al inicio
                </a>
            </div>
        </form>
    </div>
</div>