<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>



<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.13/dist/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/Draggable.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.13.0/gsap.min.js"></script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.12.3/umd/popper.min.js" integrity="sha384-vFJXuSJphROIrBnz7yo7oB41mKfc8JzQZiCq4NCceLEaO4IHwicKwpJf9c9IpFgh"
        crossorigin="anonymous"></script>
<script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.0.0-beta.2/js/bootstrap.min.js" integrity="sha384-alpBpkh1PFOepccYVYDB4do5UnbKysX5WZXm3XxPqe5iKTfUKjNkCk9SaVuEZflJ"
        crossorigin="anonymous"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/materialize/0.100.2/js/materialize.min.js"></script>
<script>
    $(".button-collapse").sideNav();
</script>

<script src="~/assets/Citas/citas.js"></script>


<script>
    var motivoConsulta, fechahoraFinal;

    var sintomasPaciente;

    $("#btnFinalizar").click(function () {
         window.location.href = "@Url.Action("Index", "Home")";
    });

    $("#btnContinuar").click(function () {
        if ($(".contenedorReloj").css("display") === "block") {
            const timeInt = parseInt(TIME.replace(":", ""));
            console.log(timeInt)
            console.log()
            if (timeInt < 500 || timeInt > 1900 || timeInt == 1200) {
                Swal.fire({
                    icon: 'error',
                    title: 'Hora no Permitida',
                    text: 'Los horarios de atención son desde 05:00 am A 12:00 pm y 01:00 pm  a 08:00 pm.',
                    confirmButtonText: 'Aceptar'
                });
            } else {
                $("#contenedorMotivo").css({ "display": 'block' });
                $(".contenedorReloj").css({ "display": 'none' });
            }
        } else if ($("#contenedorMotivo").css("display") === "block") {
                $("#fechaCita").append(" " + TIME);
                $("#contendorInformacion").css({ "display": 'block' });
                $("#contenedorMotivo").css({ "display": 'none' });
                fechahoraFinal = fechaFinal + TIME;
                console.log(fechahoraFinal = fechaFinal + " " + TIME)
                sintomasPaciente = $('#txtSintomas').val();
                $("#textoMotivo").text(sintomasPaciente);


        } else if($("#contendorInformacion").css("display") === "block") {

            if (!sintomasPaciente) {
            alert('Por favor, escribe los síntomas.');
            return;
        }
            if (!sintomasPaciente) {
                alert('Por favor, escribe los síntomas.');
                return;
            }
            $.ajax({
                url: '@Url.Action("ProcesarSintomas", "Home")',
                type: 'POST',
                data: { sintomas: sintomasPaciente },
                success: function (response) {
                    console.log('Respuesta del servidor:', response);
                 motivoConsulta = response.profesional;
                 $.ajax({
                 url: "@Url.Action("CrearCita", "Home")",
                 data: { motivo: motivoConsulta, fecha: fechahoraFinal},
                 type: "POST",
                     success: function (data) {


                     if (data.success) {
                        Swal.fire({
                            title: '¡Cita creada exitosamente!',
                            icon: 'success',
                            confirmButtonColor: '#28a745',
                            confirmButtonText: 'Genial'
                        }).then(() => {
                            window.location.href = '@Url.Action("ConfirmarCita", "Home")';
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'No se pudo crear el cliente',
                            text: data.message || 'Ocurrió un error inesperado.',
                            confirmButtonColor: '#dc3545'
                        });
                    }

                 },
                error: function (xhr, status, error) {
                     Swal.fire({
                         icon: 'error',
                         title: 'Error del servidor',
                         text: xhr.responseText || 'No se pudo completar la solicitud.',
                         confirmButtonColor: '#dc3545'
                     });
                 }
                 });


                },
                error: function (xhr, status, error) {
                    console.error('Error al contactar el servidor:', error);
                    $('#resultado').text('Error al procesar los síntomas.');
                }
            });


        } else {


        }
    });


    btnRCalendario.onclick = function () {
        if ($("#contendorInformacion").css("display") === "block") {
            $("#contendorInformacion").css({ "display": 'none' });
            $("#contenedorMotivo").css({ "display": 'block' });
        }
        else if ($("#contenedorMotivo").css("display") === "block") {
            $(".contenedorReloj").css({ "display": 'block' });
            $("#contenedorMotivo").css({ "display": 'none' });
        } else if ($(".contenedorReloj").css("display") === "block") {
            $(".main-wrapper").css({ "display": 'block' });
            $(".contenedorReloj").css({ "display": 'none' });
            $("#btnContinuar").css({ "display": 'none' });
        } else if ($(".main-wrapper").css("display") === "block"){
            window.location.href = "@Url.Action("Index", "Home")";
        }
   }


    $('#btnEnviar').click(function () {

    });

    const INPUT = document.querySelector('[type=range]')
    const ROTATE_MAPPER = gsap.utils.mapRange(0, INPUT.max, 0, 360)
    const PROGRESS_MAPPER = gsap.utils.mapRange(0, INPUT.max * 0.5, 0, 50)
    gsap.registerPlugin(Draggable)
    gsap.set('[title="moon"]', { scale: 0 })
    const minToTime = minutes => `${`${Math.floor(minutes / 60)}`.padStart(2, '0')}:${`${Math.floor(minutes % 60)}`.padStart(2, '0')}`

    const SUNRISE = 420
    const SUNSET = 420 + (12 * 60)
    // let rotationSnap = 360 / 24
    let rotationSnap = 15
    var TIME
    const onInput = function () {
        if (this.rotation) {
            let VALUE = Math.floor(((this.rotation % 360) / 360) * INPUT.max)
            if (VALUE < 0) VALUE = INPUT.max - Math.abs(VALUE)
            INPUT.value = VALUE
            INPUT.value = parseFloat(INPUT.value);

        } else {
            gsap.set('.radial__ring', {
                rotate: ROTATE_MAPPER(INPUT.value)
            })
        }
         TIME = minToTime(gsap.utils.wrap(0, 1440, parseInt(INPUT.value, 10) + (SUNSET + (SUNRISE - SUNSET) * 0.5)))
        gsap.set('.radial__time', {
            innerText: TIME
        })

        console.log("hora"+TIME)



        gsap.set('.radial__handle', {
            rotate: ROTATE_MAPPER(-INPUT.value)
        })
        if (INPUT.value > INPUT.max * 0.25 && INPUT.value < INPUT.max * 0.75) {
            gsap.to('[title="sun"]', { scale: 0, duration: 0.25 });
            gsap.to('[title="moon"]', { scale: 1, duration: 0.25 });
            gsap.set('.radial__handle', { background: 'var(--gray-8)' });
            gsap.set('.contenedorReloj', { background: 'var(--surface-1)' });
            gsap.set('.radial__time', { color: 'var(--text-1)' });
        } else {
            gsap.to('[title="moon"]', { scale: 0, duration: 0.25 });
            gsap.to('[title="sun"]', { scale: 1, duration: 0.25 });
            gsap.set('.radial__handle', { background: 'var(--gray-0)' });
            gsap.set('.contenedorReloj', { background: 'var(--text-1)' });
            gsap.set('.radial__time', { color: 'var(--surface-1)' });
        }
        // Based on the value work out the conic-gradient percentages...
        // Remember the ring starts at 0 and the input at 0 but the stops are offset.
        const sunInput = INPUT.value > INPUT.max * 0.75 ? parseInt(INPUT.value, 10) - INPUT.max * 0.75 : parseInt(INPUT.value, 10) + INPUT.max * 0.25
        const moonInput = INPUT.value > INPUT.max * 0.75 ? 0 : INPUT.value - INPUT.max * 0.25
        gsap.set('.radial__track', {
            '--sun-stop': gsap.utils.clamp(0, 50, PROGRESS_MAPPER(sunInput)),
            '--moon-stop': gsap.utils.clamp(0, 50, PROGRESS_MAPPER(moonInput))
        })
    }

    window.__RADIAL = Draggable.create(".radial__ring", {
        trigger: '.radial__handle',
        type: "rotation",
        inertia: true,
        onThrowUpdate: onInput,
        onDrag: onInput,
        snap: function (endValue) {
            return Math.round(endValue / rotationSnap) * rotationSnap;
        }
    });

    INPUT.addEventListener('input', onInput)
    onInput()

</script>



