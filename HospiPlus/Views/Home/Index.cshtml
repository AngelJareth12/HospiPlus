<script>
    function logout()
    {
       window.location.href = '@Url.Action("Login", "Home")';
    }

    document.getElementById("imagenClickable").addEventListener("click", function () {
        document.getElementById("imagenPerfilInput").click();
    });

    $(function () {
        $('.material-card > .mc-btn-action').click(function (){
            var card = $(this).parent('.material-card');
            var icon = $(this).children('i');
            icon.addClass('fa-spin-fast');

            if (card.hasClass('mc-active')) {
                card.removeClass('mc-active');

                window.setTimeout(function () {
                    icon
                        .removeClass('fa-arrow-left')
                        .removeClass('fa-spin-fast')
                        .addClass('fa-bars');

                }, 800);
            } else {
                card.addClass('mc-active');

                window.setTimeout(function () {
                    icon
                        .removeClass('fa-bars')
                        .removeClass('fa-spin-fast')
                        .addClass('fa-arrow-left');

                }, 800);
            }
        });
    });

    const input = document.getElementById("search-input");
    const searchBtn = document.getElementById("search-btn");
    const expand = () => {
        searchBtn.classList.toggle("close");
        input.placeholder = "Buscar Nombre o Especialidad";
        input.classList.toggle("square");
    };
    searchBtn.addEventListener("click", function () {
        expand();
        // Check if the 'close' class is now present on the button
        if (!searchBtn.classList.contains("close")) {
            input.placeholder = ""; // If 'close' is present, clear the placeholder
        } else {
            // If 'close' is removed, set the placeholder back
            input.placeholder = "Buscar Nombre o Especialidad";
        }
    });
</script>

