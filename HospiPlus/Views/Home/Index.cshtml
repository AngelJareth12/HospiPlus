        <article class="resume" data-page="asistente">
            <header>
                <h2 class="h2 article-title">Asistente</h2>
            </header>
            <section id="sectionChat">
                <style>
                    #sectionChat {
                        font-family: Arial, sans-serif;            
                        background: url("https://www.transparenttextures.com/patterns/45-degree-fabric-light.png");
                        margin: 0;
                        padding: 0;
                        display: flex;
                        justify-content: center;
                        align-items: center;
                        height: 100vh;
                    }

                    .chat {
                        width: 100%;
                        height: 100%;
                        background: #fff;
                        border-radius: 10px;
                        box-shadow: 0 5px 15px rgba(0,0,0,0.2);
                        display: flex;
                        flex-direction: column;
                    }
                .chat-title {
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 15px;
                border-bottom: 1px solid #eee;
                }
                .chat-title h2 {
                margin: 0;
                font-size: 20px;
                }
                .chat-title .avatar img {
                width: 40px;
                height: 40px;
                border-radius: 50%;
                }
                .messages {
                flex: 1;
                overflow-y: auto;
                padding: 15px;
                }
                .messages-content {
                display: flex;
                flex-direction: column;
                gap: 10px;
                }
                .message {
                background: #e0e0e0;
                padding: 10px;
                border-radius: 10px;
                max-width: 70%;
                align-self: flex-start;
                }
                .message.self {
                background: #d1e7dd;
                align-self: flex-end;
                }
                .action-box {
                display: flex;
                border-top: 1px solid #eee;
                }
                .action-box-input {
                flex: 1;            
                padding: 10px;
                border: none;
                outline: none;
                font-size: 14px;
                }
                .action-box-submit {
                background: none;
                border: none;
                padding: 0 15px;
                font-size: 18px;
                cursor: pointer;
                color: #007bff;
                }
                </style>
                <div class="chat">
                    <div class="chat-title">
                        <h2>Aquile (Asistente)</h2>
                        <figure class="avatar">
                            <img src="https://s3-us-west-2.amazonaws.com/s.cdpn.io/764024/profile/profile-512.jpg" alt="Avatar">
                        </figure>
                    </div>
                    <div class="messages">
                        <div class="messages-content" id="messages-content">
                            <!-- Messages will appear here -->
                        </div>
                    </div>
                    <div class="action-box">
                        <textarea style="width:90%;" class="action-box-input" id="message-input" placeholder="Type message..."></textarea>
                        <button class="action-box-submit" onclick="insertMessage()">
                            <i class="fa fa-paper-plane"></i>
                        </button>
                    </div>
                </div>

                <script>
                    const messagesContent = document.getElementById("messages-content");
                    const messageInput = document.getElementById("message-input");
                    let fakeNum = 0;
                    let isTyping = true;
                    let uctTimer = null;
                    var mensajeEnviado;
                    const fakeMsg = [
                        "Hola soy Aquile, como te ayudo?",
                        "Nice to meet you",
                        "How are you doing?",
                        "Pretty good",
                        "How's life been treating you?",
                        "It could be worse, thanks",
                        "I've gotta go now",
                        "It was a pleasure chat with you",
                        "Bye :)"
                    ];

                    function userTypingClear() {
                        clearTimeout(uctTimer);
                        uctTimer = setTimeout(() => {
                            const typingMsg = document.querySelector(".message.personal.typing");
                            if (typingMsg) typingMsg.remove();
                            isTyping = true;
                        }, 3500);
                    }

                    function setDate() {
                        const timestamp = document.createElement("div");
                        timestamp.className = "timestamp";
                        const now = new Date();
                        const minutes = now.getMinutes() < 10 ? '0' + now.getMinutes() : now.getMinutes();
                        timestamp.textContent = `${now.getHours()}:${minutes}`;
                        const lastMsg = messagesContent.lastElementChild;
                        if (lastMsg) lastMsg.appendChild(timestamp);
                    }

                    function updateScrollbar() {
                        messagesContent.parentElement.scrollTop = messagesContent.scrollHeight;
                    }

                    function setFakeMessage() {
                        const typing = document.createElement("div");
                        typing.className = "message typing";
                        const dot = document.createElement("span");
                        typing.appendChild(dot);
                        messagesContent.appendChild(typing);
                        updateScrollbar();

                        setTimeout(() => {
                            typing.remove();
                            const msg = document.createElement("div");
                            msg.className = "message";
                            if (fakeNum < 1) {
                                msg.textContent = fakeMsg[fakeNum] || "...";
                            } else {
                                $.ajax({
                                url: '@Url.Action("Asistencia", "Home")',
                                type: 'POST',
                                    data: { mensaje: mensajeEnviado},
                                success: function (response) {
                                    console.log('Respuesta del servidor:', response);
                                    msg.textContent = response.profesional
                                },
                                    error: function (xhr, status, error) {
                                        msg.textContent = 'Error al contactar el servidor:', error;
                                }
                                });
                            }
                            messagesContent.appendChild(msg);
                            setDate();
                            updateScrollbar();
                            fakeNum++;
                        }, 1000 + Math.random() * 1000);
                    }

                    function insertMessage() {
                        const text = messageInput.value.trim();
                        mensajeEnviado = text;
                        if (text === "") return;

                        const msg = document.createElement("div");
                        msg.className = "message personal self";
                        msg.textContent = text;
                        messagesContent.appendChild(msg);
                        setDate();
                        updateScrollbar();
                        

                        const typingMsg = document.querySelector(".message.personal.typing");
                        if (typingMsg) typingMsg.remove();
                        isTyping = true;
                        clearTimeout(uctTimer);
                        if (fakeNum < 1) {
                            if (fakeMsg[fakeNum]) {
                                setTimeout(setFakeMessage, 500 + Math.random() * 1000);
                            }
                        } else {
                            setTimeout(setFakeMessage, 500 + Math.random() * 1000);
                        }
                        messageInput.value = "";
                    }

                    window.addEventListener("keydown", function (e) {
                        if (e.key === "Enter" && !e.shiftKey) {
                            e.preventDefault();
                            insertMessage();
                        }
                    });

                    messageInput.addEventListener("keydown", function (e) {
                        if (messageInput.value !== "" && isTyping && e.key !== "Enter") {
                            const typing = document.createElement("div");
                            typing.className = "message personal typing";
                            const dot = document.createElement("span");
                            typing.appendChild(dot);
                            messagesContent.appendChild(typing);
                            updateScrollbar();
                            isTyping = false;
                            userTypingClear();
                        }
                    });

                    window.addEventListener("load", function () {
                        updateScrollbar();
                        setTimeout(setFakeMessage, 100);
                    });
                </script>
            </section>
        </article>

